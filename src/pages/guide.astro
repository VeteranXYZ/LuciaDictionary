---
import MainLayout from "../layouts/MainLayout.astro";
import InfoPageShell from "../components/InfoPageShell.astro";
import { buildInfoPageStructuredData } from "../lib/seo.js";

const title = "Lucia's Dictionary 使用指南";
const description =
  "了解如何输入或拍下课堂英语句子、生成单词卡、收藏生词、完成课堂小练习，以及使用键盘、屏幕阅读器和浏览器缩放。";
const canonicalPath = "/guide/";
const guideSteps = [
  "输入或粘贴中文、英文课堂句子，也可以拍照识别题目中的英文。",
  "点击“生成单词卡”，查看句子中的英文单词、中文释义和音标。",
  "点击单词卡听发音；遇到不熟悉的词，点星标收藏到生词本。",
  "开始 3 分钟课堂小练习，完成听音、选词和原句填空。",
  "到生词本标记“会”“不确定”或“忘记”，让复习安排更合适。",
  "需要更换设备时，先备份生词本，再在新设备中导入备份。",
];
const structuredData = buildInfoPageStructuredData({
  path: canonicalPath,
  title,
  description,
});
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={title}
  appScript={false}
  structuredData={structuredData}
>
  <InfoPageShell title="Guide" titleZh="使用指南" current="guide">
    <ol class="steps">
      {guideSteps.map((step) => <li>{step}</li>)}
    </ol>
    <section>
      <h2>适合输入什么内容</h2>
      <p>
        最适合作业要求、阅读问题、数学题目、科学笔记和老师的简短指令。也可以输入单个英文词，但完整句子能帮助孩子把单词放回真实课堂情境中理解。
      </p>
    </section>
    <section>
      <h2>学习记录保存在哪里</h2>
      <p>
        生词本、复习记录和朗读设置保存在当前浏览器中，不会生成公开的搜索页面或共享的搜索历史。清除浏览器数据前，建议先备份生词本。
      </p>
    </section>
    <section>
      <h2>无障碍使用</h2>
      <p>
        主要操作支持键盘完成；输入框、图标按钮和底部导航提供屏幕阅读器可识别的名称；单词卡生成结果和图片识别进度会自动播报。页面允许浏览器缩放，并会遵循系统的“减少动态效果”设置。
      </p>
      <p>
        单词卡同时提供英文文字、中文释义、音标和发音，孩子可以结合看、听和反复收藏练习，不必只依赖一种信息形式。
      </p>
    </section>
    <section>
      <h2>已知限制与反馈</h2>
      <p>
        发音质量和朗读时的单词高亮效果取决于浏览器和操作系统，自动检查也无法覆盖所有辅助技术组合。如果遇到使用障碍，可以通过应用设置页中的邮箱链接反馈。
      </p>
    </section>
  </InfoPageShell>
</MainLayout>
