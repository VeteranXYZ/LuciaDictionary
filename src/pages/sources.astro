---
import MainLayout from "../layouts/MainLayout.astro";
import InfoPageShell from "../components/InfoPageShell.astro";
import { buildInfoPageStructuredData } from "../lib/seo.js";

const title = "Lucia's Dictionary 数据来源";
const description =
  "了解 Lucia's Dictionary 使用的本地词典、课堂短句、音标、联网查词、翻译和图片文字识别服务。";
const canonicalPath = "/sources/";
const structuredData = buildInfoPageStructuredData({
  path: canonicalPath,
  title,
  description,
});
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={title}
  appScript={false}
  structuredData={structuredData}
>
  <InfoPageShell
    title="Dictionary Sources and Attribution"
    titleZh="词典数据来源"
    current="sources"
  >
    <p>
      Lucia's Dictionary
      会先使用随应用提供的词典和课堂短句；本地内容不足时，才会按需使用联网查词、翻译或图片文字识别服务。不同来源的结果可能存在差异。
    </p>
    <section>
      <h2>本地词典与课堂短句</h2>
      <p>
        应用包含一份适合浏览器使用的核心词典、基础备用词表、常见课堂短句和音标提示。常用内容可以直接在设备上查询，但并不代表所有英文词都一定有完整的本地释义。
      </p>
    </section>
    <section>
      <h2>词典数据来源</h2>
      <p>
        核心词典由高频词汇数据和 ECDICT
        等公开词典数据整理生成。页面上的“基础词、进阶词、拓展词”用于帮助安排学习顺序，不代表学校年级标准或考试等级认证。
      </p>
    </section>
    <section>
      <h2>课堂短句</h2>
      <p>
        课堂短句覆盖常见的作业要求、阅读指令、数学和科学提示以及课堂习惯表达。输入相近的中文或英文短句时，应用会优先在这些内容中查找。
      </p>
    </section>
    <section>
      <h2>联网补充</h2>
      <p>
        本地内容不足时，应用可能通过 dictionaryapi.dev 补充英文释义，并通过
        Google
        翻译备用服务生成中文结果。联网结果可能随服务状态而变化，并会缓存在当前浏览器中。
      </p>
    </section>
    <section>
      <h2>图片文字识别</h2>
      <p>
        拍照识别英文时，图片会先在浏览器中压缩，再通过本站接口发送给 OCR.Space
        完成文字识别。关于图片和识别结果如何处理，请查看“隐私与数据”页面。
      </p>
    </section>
  </InfoPageShell>
</MainLayout>
