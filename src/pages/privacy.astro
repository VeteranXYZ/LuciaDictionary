---
import MainLayout from "../layouts/MainLayout.astro";
import InfoPageShell from "../components/InfoPageShell.astro";
import { buildInfoPageStructuredData } from "../lib/seo.js";

const title = "Lucia's Dictionary 隐私与数据说明";
const description =
  "了解 Lucia's Dictionary 如何在浏览器中保存生词本和设置，什么时候会使用联网查词、翻译、图片识别及基础访问统计。";
const canonicalPath = "/privacy/";
const structuredData = buildInfoPageStructuredData({
  path: canonicalPath,
  title,
  description,
});
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={title}
  appScript={false}
  structuredData={structuredData}
>
  <InfoPageShell title="Privacy" titleZh="隐私与数据" current="privacy">
    <p>
      Lucia's Dictionary
      尽量把学习数据保存在当前浏览器中。它不提供账号、公开个人主页、搜索历史分享、个性化广告或云端生词本同步功能。
    </p>
    <section>
      <h2>先说结论</h2>
      <ul>
        <li>生词本、复习记录和设置默认保存在当前浏览器中。</li>
        <li>输入的句子、上传的图片和生词本内容不会发送给 Google Analytics。</li>
        <li>本地内容不足时，查词和翻译功能可能会访问第三方服务。</li>
        <li>使用拍照识别时，所选图片会发送给 OCR.Space 处理。</li>
      </ul>
    </section>
    <section>
      <h2>保存在浏览器里的内容</h2>
      <p>
        已收藏单词、单词出现过的课堂原句、课堂小练习结果、复习安排、朗读设置、连续学习天数和查询缓存，会通过
        localStorage
        保存在当前浏览器中。清除浏览器数据或更换设备后，这些本地数据可能丢失或无法自动同步。
      </p>
    </section>
    <section>
      <h2>什么时候会联网</h2>
      <p>
        大部分英文单词卡使用应用自带的数据。本地内容不足时，单词可能会发送给
        dictionaryapi.dev 查询，其释义可能通过 Google
        翻译备用服务转换成中文。输入中文句子时，应用会先查询本地课堂短句；没有合适结果时才使用联网翻译。
      </p>
      <p>
        拍照识别会先在浏览器中压缩所选图片，再通过本站的图片识别接口转发给
        OCR.Space。本站服务器不会保存上传的图片或识别结果，接口响应也设置为不缓存。Cloudflare
        在提供网站和接口服务时，可能处理必要的安全与性能数据。
      </p>
    </section>
    <section>
      <h2>基础访问统计</h2>
      <p>
        网站使用 Google Analytics 4 了解公开页面的访问和会话情况。GA4
        会通过第一方 <code>_ga</code> 等 Cookie 区分浏览器和会话，并处理访问页面、时间、来源、粗略地区以及浏览器和设备类别。本站已关闭增强型衡量、Google
        信号及所有广告和个性化功能，也不会把输入的句子、上传的图片、查过或收藏的单词、生词本内容、账号身份或自定义学习事件发送给
        Analytics。你可以通过浏览器设置查看或清除这些 Cookie。
      </p>
    </section>
    <section>
      <h2>儿童隐私提醒</h2>
      <p>
        请不要输入或上传包含学校名称、家庭地址、出生日期、日程、私人照片或账号信息等儿童隐私内容。题目可以手动输入时，建议优先输入文字。
      </p>
    </section>
    <section>
      <h2>你可以怎样管理数据</h2>
      <p>
        你可以在设置页清除查询缓存，在生词本中移除单个词或清空全部单词，也可以备份生词本。还可以通过浏览器设置清除此网站保存在本机的数据。
      </p>
    </section>
  </InfoPageShell>
</MainLayout>
