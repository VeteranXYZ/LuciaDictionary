---
import MainLayout from "../layouts/MainLayout.astro";
import InfoPageShell from "../components/InfoPageShell.astro";
import { buildInfoPageStructuredData } from "../lib/seo.js";

const title = "Lucia's Dictionary 无障碍使用说明";
const description =
  "了解 Lucia's Dictionary 对键盘操作、屏幕阅读器、浏览器缩放、减少动态效果和多种学习方式的支持。";
const canonicalPath = "/accessibility/";
const structuredData = buildInfoPageStructuredData({
  path: canonicalPath,
  title,
  description,
});
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={title}
  appScript={false}
  structuredData={structuredData}
>
  <InfoPageShell
    title="Accessibility"
    titleZh="无障碍使用"
    current="accessibility"
  >
    <p>
      Lucia's Dictionary
      主要面向手机和现代浏览器使用。界面采用较大的操作控件和清晰的单词卡，同时支持键盘操作，并为主要输入框和图标按钮提供可识别的文字名称。
    </p>
    <section>
      <h2>目前支持</h2>
      <p>
        主要输入框和图标按钮带有屏幕阅读器可识别的名称；底部导航会说明当前页面；单词卡生成结果和图片识别进度会自动播报。主要操作都可以通过键盘完成，页面允许浏览器缩放，也会遵循系统的“减少动态效果”设置。
      </p>
    </section>
    <section>
      <h2>多种学习方式</h2>
      <p>
        单词卡同时提供英文文字、中文释义、音标和发音。孩子既可以看，也可以听，还能把不熟悉的词收藏起来反复练习，减少只依赖一种信息形式带来的困难。
      </p>
    </section>
    <section>
      <h2>已知限制</h2>
      <p>
        发音质量和朗读时的单词高亮效果取决于浏览器和操作系统。自动检查与键盘测试无法覆盖所有辅助技术组合；如果遇到使用障碍，可以通过应用设置页中的邮箱链接反馈。
      </p>
    </section>
  </InfoPageShell>
</MainLayout>
