---
import MainLayout from "../layouts/MainLayout.astro";
import InfoPageShell from "../components/InfoPageShell.astro";
import { buildInfoPageStructuredData, pageUrl, siteName } from "../lib/seo.js";

const title = "How to Use Lucia's Dictionary";
const description =
  "Use Lucia's Dictionary by entering a classroom sentence, reviewing word cards, completing a contextual Classroom Relay mission, and saving progress locally.";
const canonicalPath = "/how-to/";
const howToSteps = [
  "Enter or paste a Chinese or English classroom sentence.",
  "Use the action button to create word cards.",
  "Review each English word, Chinese meaning, and phonetic hint.",
  "Start Classroom Relay to see which words are recommended and why.",
  "Complete listening, meaning, and original-sentence cloze practice.",
  "Review the parent handoff prompt and revisit due words later.",
];
const structuredData = [
  ...buildInfoPageStructuredData({
    path: canonicalPath,
    title,
    description,
  }),
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "How to use Lucia's Dictionary",
    description,
    url: pageUrl(canonicalPath),
    inLanguage: ["en", "zh-CN"],
    tool: {
      "@type": "HowToTool",
      name: siteName,
    },
    step: howToSteps.map((text, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      text,
    })),
  },
];
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={title}
  appScript={false}
  structuredData={structuredData}
>
  <InfoPageShell
    title="How to Use Lucia's Dictionary"
    titleZh="使用方法"
    current="how-to"
  >
    <ol class="steps">
      {howToSteps.map((step) => <li>{step}</li>)}
    </ol>
    <section>
      <h2>What You Can Search</h2>
      <p>
        The app works best with classroom sentences, homework directions,
        reading questions, math prompts, science notes, and short teacher
        instructions. It can also accept single words, but its main workflow is
        sentence-first.
      </p>
    </section>
    <section>
      <h2>Search States</h2>
      <p>
        Searches happen inside the app. They do not create public word pages,
        saved search pages, accounts, or shared search histories.
      </p>
    </section>
  </InfoPageShell>
</MainLayout>
