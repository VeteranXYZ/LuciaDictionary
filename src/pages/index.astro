---
import MainLayout from "../layouts/MainLayout.astro";
import packageJson from "../../package.json";
import {
  siteAlternateNames,
  siteLogo,
  siteName,
  siteOrigin,
} from "../lib/seo.js";

const title =
  "Lucia's Dictionary · English Sentence Dictionary for Bilingual Learners";
const description =
  "Search or paste English classroom sentences, then get word cards with Chinese meanings, phonetics, pronunciation practice, and local review tools.";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    alternateName: siteAlternateNames,
    url: siteOrigin,
    description,
    inLanguage: ["en", "zh-CN"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: siteName,
    alternateName: siteAlternateNames,
    url: siteOrigin,
    image: siteLogo,
    applicationCategory: "EducationalApplication",
    applicationSubCategory: "English sentence dictionary",
    operatingSystem: "Any modern web browser",
    browserRequirements: "Requires a modern browser with JavaScript enabled",
    description,
    inLanguage: ["en", "zh-CN"],
    isAccessibleForFree: true,
    educationalUse: [
      "English vocabulary practice",
      "Classroom sentence comprehension",
      "Pronunciation practice",
    ],
    audience: {
      "@type": "EducationalAudience",
      educationalRole: ["student", "parent"],
    },
    featureList: [
      "Sentence-first English word cards",
      "Chinese meanings for classroom vocabulary",
      "Phonetic hints and speech playback",
      "Local wordbook review",
      "Classroom phrase practice",
      "Explainable classroom-sentence learning missions",
      "Original-context cloze practice and parent handoff prompts",
    ],
  },
];
---

<MainLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <main class="app" id="main-content">
    <div class="sr-only" id="app-status" role="status" aria-live="polite"></div>
    <header class="brand">
      <button
        class="brand-logo"
        id="brand-home-btn"
        type="button"
        aria-label="返回首页"
      >
        <img
          src="assets/logo.png"
          width="512"
          height="512"
          alt="Lucia's Dictionary"
        />
      </button>
      <div class="brand-text">
        <div class="brand-title">Lucia's Dictionary</div>
        <div class="brand-sub">Lucia 的小学英语学习伙伴</div>
      </div>
      <div class="brand-streak" title="今日学习">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"
          ><path
            d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14a8 8 0 0 0 16 0C20 9.91 18.04 6.27 14.91 3.79L13.5.67z"
          ></path></svg
        >
        <span id="streak-label">Day 1</span>
      </div>
    </header>

    <div
      class="page active"
      id="pg-home"
      role="tabpanel"
      aria-labelledby="nav-home"
    >
      <section class="hero">
        <div class="hero-center">
          <div class="hero-mascot">
            <img
              src="assets/lucia.png"
              width="768"
              height="768"
              fetchpriority="high"
              alt="Lucia"
            />
          </div>
          <div class="hero-copy">
            <h1 class="hero-title">今天想读懂哪句话？</h1>
            <p class="hero-sub">
              输入中文或英文课堂句子，<br />把它拆成可朗读、可复习的单词卡
            </p>
          </div>
        </div>
      </section>

      <div class="input-card">
        <label class="sr-only" for="sentence-input"
          >输入中文或英文课堂句子</label
        >
        <div class="input-row">
          <textarea
            id="sentence-input"
            placeholder="输入作业、阅读、数学或课堂英文句子…"
            rows="2"></textarea>
          <div class="input-actions">
            <button
              class="btn-camera"
              id="camera-btn"
              type="button"
              title="拍照或选择图片识别英文"
              aria-label="拍照或选择图片识别英文"
              aria-haspopup="dialog"
              aria-controls="image-source-dialog"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M14.5 4 16 7h3a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h3l1.5-3h5z"
                ></path><circle cx="12" cy="13" r="3.5"></circle></svg
              >
            </button>
            <input
              class="sr-only"
              type="file"
              id="camera-input"
              accept="image/*"
              capture="environment"
            />
            <input
              class="sr-only"
              type="file"
              id="image-input"
              accept="image/*"
            />
            <button
              class="btn-go"
              id="go-btn"
              title="翻译并学习"
              aria-label="翻译并学习"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.35"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 5h12"></path><path d="M9 3v2"></path><path
                  d="M5 9c1.2 3 3.5 5 7 6"></path><path
                  d="M12 5c-.7 4.4-3.1 7.3-7 9"></path><path d="M14 21l4-9 4 9"
                ></path><path d="M15.5 18h5"></path></svg
              >
            </button>
          </div>
        </div>
        <div
          class="ocr-status"
          id="ocr-status"
          role="status"
          aria-live="polite"
          hidden
        >
        </div>
      </div>

      <dialog
        class="image-source-dialog"
        id="image-source-dialog"
        aria-labelledby="image-source-title"
      >
        <form method="dialog" class="image-source-sheet">
          <div class="image-source-handle" aria-hidden="true"></div>
          <div class="image-source-copy">
            <h2 id="image-source-title">识别图片里的英文</h2>
            <p>拍清楚题目区域，识别会更准确</p>
          </div>
          <div class="image-source-actions">
            <label class="image-source-option primary" for="camera-input">
              <span class="image-source-option-icon" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M14.5 4 16 7h3a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h3l1.5-3h5z"
                  ></path><circle cx="12" cy="13" r="3.5"></circle></svg
                >
              </span>
              <span><strong>拍照</strong><small>调用后置相机</small></span>
            </label>
            <label class="image-source-option" for="image-input">
              <span class="image-source-option-icon" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect x="3" y="3" width="18" height="18" rx="3"
                  ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path
                    d="m21 15-5-5L5 21"></path></svg
                >
              </span>
              <span
                ><strong>从相册选择</strong><small>相机画面异常时也可使用</small
                ></span
              >
            </label>
          </div>
          <button class="image-source-cancel" value="cancel" type="submit"
            >取消</button
          >
        </form>
      </dialog>

      <div class="sentence-bar" id="sentence-bar">
        <div class="label">原句</div>
        <div class="text" id="sentence-text"></div>
        <div class="sentence-actions">
          <button class="speak-btn" id="speak-sentence-btn" type="button">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M11 5 6 9H2v6h4l5 4V5z"></path><path
                d="M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg
            >
            <span id="speak-sentence-label">朗读整句</span>
          </button>
          <button class="speak-btn" id="copy-sentence-btn" type="button">
            <svg
              id="copy-sentence-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="9" y="9" width="11" height="11" rx="2"></rect><path
                d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
              ></path></svg
            >
            <span id="copy-sentence-label">复制文本</span>
          </button>
        </div>
      </div>

      <div class="word-list" id="word-list">
        <div class="empty">
          <div class="empty-mascot">
            <img src="assets/monkey.png" width="256" height="256" alt="" />
          </div>
          <p>
            把老师布置的中文或英文句子粘贴上去吧～<br /><strong
              >我会帮你拆出每一个英文单词</strong
            >
          </p>
        </div>
      </div>

      <section
        class="classroom-mission"
        id="classroom-mission"
        aria-label="课堂接力学习任务"
        hidden
      >
      </section>

      <div class="tip" id="learning-tip">
        <div class="tip-icon">i</div>
        <div class="tip-text">
          <span class="hl">小提示：</span>
          点击单词卡片就能听到发音，点 <strong>☆</strong> 把不认识的单词收藏到生词本，下次再复习。
        </div>
        <button
          class="tip-close"
          id="tip-close-btn"
          type="button"
          aria-label="关闭小提示">×</button
        >
      </div>
    </div>

    <div
      class="page"
      id="pg-wordbook"
      role="tabpanel"
      aria-labelledby="nav-wordbook"
      hidden
    >
      <section class="hero" style="padding-top:0">
        <h1 class="hero-title">我的生词本</h1>
        <p class="hero-sub">把不熟的单词都收在这里，<br />常常翻翻就记住啦</p>
      </section>

      <div class="wb-stats" id="wb-stats" style="display:none"></div>

      <div class="wb-actions" id="wb-actions" style="display:none">
        <button class="btn-action moss" id="review-all-btn">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M11 5 6 9H2v6h4l5 4V5z"></path><path
              d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path
              d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg
          >
          <span>朗读</span>
        </button>
        <button class="btn-action honey" id="export-wb-btn">
          <span>导出</span>
        </button>
        <button class="btn-action ink" id="import-wb-btn">
          <span>导入</span>
        </button>
        <input
          id="import-wb-input"
          type="file"
          accept="application/json,.json"
          hidden
        />
        <button class="btn-action danger" id="clear-wb-btn">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="3 6 5 6 21 6"></polyline><path
              d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path
              d="M10 11v6"></path><path d="M14 11v6"></path></svg
          >
          <span>清空</span>
        </button>
      </div>

      <div class="word-list" id="wb-list"></div>
    </div>

    <div
      class="page"
      id="pg-quiz"
      role="tabpanel"
      aria-labelledby="nav-quiz"
      hidden
    >
      <section class="hero" style="padding-top:0">
        <h1 class="hero-title">单词测验</h1>
        <p class="hero-sub">
          用生词本里的单词出题，<br />读一读、听一听、选一选
        </p>
      </section>

      <div id="quiz-content"></div>
    </div>

    <div
      class="page"
      id="pg-templates"
      role="tabpanel"
      aria-labelledby="nav-templates"
      hidden
    >
      <section class="hero" style="padding-top:0">
        <h1 class="hero-title">老师常说的话</h1>
        <p class="hero-sub">美国小学课堂里最常听到的指令<br />遇到了不慌张</p>
      </section>

      <div class="tpl-tabs" id="tpl-tabs"></div>
      <div class="tpl-list" id="tpl-list"></div>
    </div>

    <div
      class="page"
      id="pg-settings"
      role="tabpanel"
      aria-labelledby="nav-settings"
      hidden
    >
      <section class="hero" style="padding-top:0">
        <h1 class="hero-title">设置</h1>
        <p class="hero-sub">调一调，更顺手</p>
      </section>

      <div class="settings-surface">
        <section
          class="set-card settings-section"
          aria-labelledby="functional-settings-title"
        >
          <div class="settings-module-head">
            <div class="settings-module-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="3"></circle><path
                  d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.05.05-2.83 2.83-.05-.05a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21h-4v-.08a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.05.05-2.83-2.83.05-.05A1.7 1.7 0 0 0 4.6 15 1.7 1.7 0 0 0 3.08 14H3v-4h.08A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.87l-.05-.05 2.83-2.83.05.05a1.7 1.7 0 0 0 1.87.34A1.7 1.7 0 0 0 10 3.08V3h4v.08a1.7 1.7 0 0 0 1.04 1.56 1.7 1.7 0 0 0 1.87-.34l.05-.05 2.83 2.83-.05.05A1.7 1.7 0 0 0 19.4 9 1.7 1.7 0 0 0 20.92 10H21v4h-.08A1.7 1.7 0 0 0 19.4 15z"
                ></path></svg
              >
            </div>
            <div>
              <h2 id="functional-settings-title">功能设置</h2>
              <p>调整朗读方式与本地查询数据</p>
            </div>
          </div>

          <div class="set-group">
            <div class="set-label">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><polyline
                  points="12 6 12 12 16 14"></polyline></svg
              >
              朗读速度
            </div>
            <div class="set-info">单词朗读快慢，慢速适合初学</div>
            <div class="set-options" id="speed-options"></div>
          </div>

          <div class="set-group">
            <div class="set-label">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="23 4 23 10 17 10"></polyline><path
                  d="M20.49 15A9 9 0 1 1 18 5.34"></path></svg
              >
              朗读次数
            </div>
            <div class="set-info">点单词时连续朗读几遍</div>
            <div class="set-options" id="repeat-options"></div>
          </div>

          <div class="set-group">
            <div class="set-label">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M21 12a9 9 0 0 1-9 9"></path><path
                  d="M3 12a9 9 0 0 1 9-9"></path><path d="M12 3v4"></path><path
                  d="M12 17v4"></path><path d="M3 12h4"></path><path
                  d="M17 12h4"></path></svg
              >
              查询缓存
            </div>
            <div class="set-info">清除自动音标、在线释义和中文翻译缓存</div>
            <button
              class="set-btn cache-clear-btn"
              id="clear-cache-btn"
              type="button">清除查询缓存</button
            >
          </div>
        </section>

        <section
          class="settings-info settings-section"
          aria-labelledby="settings-info-title"
        >
          <div class="settings-info-head">
            <div class="settings-info-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="9"></circle><path d="M12 11v5"
                ></path><path d="M12 8h.01"></path></svg
              >
            </div>
            <div>
              <h2 id="settings-info-title">产品与使用帮助</h2>
              <p>使用说明、数据来源与隐私保护</p>
            </div>
          </div>
          <nav class="settings-info-links" aria-label="产品信息与帮助">
            <a href="/about/"><span>关于词典</span><small>About</small></a>
            <a href="/how-to/"><span>使用方法</span><small>How to Use</small></a
            >
            <a href="/sources/"><span>数据来源</span><small>Sources</small></a>
            <a href="/privacy/"><span>隐私保护</span><small>Privacy</small></a>
            <a href="/accessibility/"
              ><span>无障碍</span><small>Accessibility</small></a
            >
          </nav>
          <p class="settings-info-note" lang="en">
            A sentence-first dictionary for Chinese-speaking families learning
            classroom English.
          </p>
        </section>

        <div class="about">
          <div class="about-mascot">
            <img
              src="assets/lucia.png"
              width="768"
              height="768"
              loading="lazy"
              alt=""
            />
          </div>
          <div class="about-name">Lucia's Dictionary</div>
          <div class="about-ver">v{packageJson.version} · 2026</div>
          <div class="about-tag">For Lucia's elementary school studies</div>

          <div class="about-stats">
            <div class="about-stat">
              <div class="v" id="dict-count">0</div>
              <div class="l">收录单词</div>
            </div>
            <div class="about-stat">
              <div class="v" id="about-wb-count">0</div>
              <div class="l">已收藏单词</div>
            </div>
          </div>

          <div class="about-divider"></div>

          <div class="about-foot">
            <p>
              © 2026 <strong>Lucia &amp; Rayna</strong> · Powered by <strong
                >HIEI</strong
              >
            </p>
            <p style="margin-top:4px">
              <a href="mailto:hello@luciaandrayna.com"
                >hello@luciaandrayna.com</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>

  </main>

  <nav class="nav" aria-label="主要功能" role="tablist">
    <button
      class="nav-item active"
      id="nav-home"
      data-pg="home"
      type="button"
      role="tab"
      aria-controls="pg-home"
      aria-selected="true"
      aria-current="page"
    >
      <span class="icon-wrap">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
          ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
        >
      </span>
      首页
    </button>
    <button
      class="nav-item"
      id="nav-wordbook"
      data-pg="wordbook"
      type="button"
      role="tab"
      aria-controls="pg-wordbook"
      aria-selected="false"
    >
      <span class="icon-wrap">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polygon
            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
          ></polygon></svg
        >
      </span>
      生词本
    </button>
    <button
      class="nav-item"
      id="nav-quiz"
      data-pg="quiz"
      type="button"
      role="tab"
      aria-controls="pg-quiz"
      aria-selected="false"
    >
      <span class="icon-wrap">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="5" y="4" width="14" height="18" rx="2"></rect><path
            d="M9 4a3 3 0 0 1 6 0"></path><path d="M9 12l2 2 4-4"></path><path
            d="M9 18h6"></path></svg
        >
      </span>
      测验
    </button>
    <button
      class="nav-item"
      id="nav-templates"
      data-pg="templates"
      type="button"
      role="tab"
      aria-controls="pg-templates"
      aria-selected="false"
    >
      <span class="icon-wrap">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path
            d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
          ></path></svg
        >
      </span>
      常用句
    </button>
    <button
      class="nav-item"
      id="nav-settings"
      data-pg="settings"
      type="button"
      role="tab"
      aria-controls="pg-settings"
      aria-selected="false"
    >
      <span class="icon-wrap">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
