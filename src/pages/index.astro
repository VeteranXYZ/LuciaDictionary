---
import packageJson from "../../package.json";
import AppHeader from "../components/app/AppHeader.astro";
import BottomNav from "../components/app/BottomNav.astro";
import HomePage from "../components/app/HomePage.astro";
import QuizPage from "../components/app/QuizPage.astro";
import SettingsPage from "../components/app/SettingsPage.astro";
import TemplatesPage from "../components/app/TemplatesPage.astro";
import WordbookPage from "../components/app/WordbookPage.astro";
import MainLayout from "../layouts/MainLayout.astro";
import {
  siteAlternateNames,
  siteLogo,
  siteName,
  siteOrigin,
} from "../lib/seo.js";

const title = "Lucia's Dictionary｜课堂英语句子学习词典";
const description =
  "输入、粘贴或拍下课堂英语句子，查看中文释义、音标和发音，并把生词保存在本地随时复习。";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    alternateName: siteAlternateNames,
    url: siteOrigin,
    description,
    inLanguage: ["en", "zh-CN"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: siteName,
    alternateName: siteAlternateNames,
    url: siteOrigin,
    image: siteLogo,
    applicationCategory: "EducationalApplication",
    applicationSubCategory: "课堂英语句子学习词典",
    operatingSystem: "Any modern web browser",
    browserRequirements: "Requires a modern browser with JavaScript enabled",
    description,
    inLanguage: ["en", "zh-CN"],
    isAccessibleForFree: true,
    educationalUse: ["英语词汇练习", "课堂句子理解", "英语发音练习"],
    audience: {
      "@type": "EducationalAudience",
      educationalRole: ["student", "parent"],
    },
    featureList: [
      "把课堂英语句子拆成单词卡",
      "提供中文释义、音标和发音",
      "在本地保存并复习生词",
      "练习常见课堂用语",
      "根据学习记录推荐课堂小练习",
      "在原句中完成听音、选词和填空练习",
    ],
  },
];
---

<MainLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <main class="app" id="main-content">
    <div class="sr-only" id="app-status" role="status" aria-live="polite"></div>
    <AppHeader />
    <HomePage />
    <WordbookPage />
    <QuizPage />
    <TemplatesPage />
    <SettingsPage version={packageJson.version} />
  </main>
  <BottomNav />
</MainLayout>
