---
import MainLayout from "../layouts/MainLayout.astro";

const title = "About Lucia's Dictionary";
const description = "Learn what Lucia's Dictionary does, who it is for, and how it supports sentence-first English vocabulary practice for bilingual families.";
---

<MainLayout title={title} description={description} canonicalPath="/about/" ogTitle={title} appScript={false}>
  <main class="info-page" id="main-content">
    <a class="back-link" href="/">Lucia's Dictionary</a>
    <h1>About Lucia's Dictionary</h1>
    <p>
      Lucia's Dictionary is an online English sentence dictionary for Chinese-speaking families.
      It is built around classroom sentences, homework instructions, reading prompts, and teacher notes.
    </p>
    <p>
      Instead of starting with one isolated word, the app starts with the full sentence. It extracts the English words,
      shows Chinese meanings and phonetics where available, reads words aloud, and lets the learner save unfamiliar words
      in a local wordbook.
    </p>
    <section>
      <h2>Who It Is For</h2>
      <p>
        The product is intended for bilingual elementary-school learners and parents who want a quick way to understand
        everyday classroom English. It is not a complete English curriculum or a replacement for teacher guidance.
      </p>
    </section>
    <section>
      <h2>Product Approach</h2>
      <p>
        The app is local-first: common classroom phrases, core words, phonetics, settings, cached lookup results, and
        saved wordbook items are handled in the browser whenever possible.
      </p>
    </section>
    <nav class="info-links" aria-label="Public pages">
      <a href="/how-to/">How to Use</a>
      <a href="/sources/">Sources</a>
      <a href="/privacy/">Privacy</a>
      <a href="/accessibility/">Accessibility</a>
    </nav>
  </main>
</MainLayout>
