---
import AppPanel from "./AppPanel.astro";

interface Props {
  version: string;
}

const { version } = Astro.props;
---

<AppPanel
  id="pg-settings"
  navId="nav-settings"
  title="设置"
  subtitle="调一调，更顺手"
>
  <div class="settings-layout">
    <section
      class="settings-card settings-preferences"
      aria-labelledby="functional-settings-title"
    >
      <header class="settings-card-head">
        <div class="settings-card-icon" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="3"></circle><path
              d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.05.05-2.83 2.83-.05-.05a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21h-4v-.08a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.05.05-2.83-2.83.05-.05A1.7 1.7 0 0 0 4.6 15 1.7 1.7 0 0 0 3.08 14H3v-4h.08A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.87l-.05-.05 2.83-2.83.05.05a1.7 1.7 0 0 0 1.87.34A1.7 1.7 0 0 0 10 3.08V3h4v.08a1.7 1.7 0 0 0 1.04 1.56 1.7 1.7 0 0 0 1.87-.34l.05-.05 2.83 2.83-.05.05A1.7 1.7 0 0 0 19.4 9 1.7 1.7 0 0 0 20.92 10H21v4h-.08A1.7 1.7 0 0 0 19.4 15z"
            ></path></svg
          >
        </div>
        <div class="settings-card-title">
          <h2 id="functional-settings-title">朗读设置</h2>
          <p>调整朗读速度与重复次数</p>
        </div>
      </header>

      <div class="settings-list">
        <div class="setting-row">
          <div class="setting-copy">
            <span class="setting-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><polyline
                  points="12 6 12 12 16 14"></polyline></svg
              >
            </span>
            <div>
              <div class="set-label">朗读速度</div>
              <div class="set-info">慢速适合刚开始练习的孩子</div>
            </div>
          </div>
          <div
            class="set-options"
            id="speed-options"
            role="group"
            aria-label="朗读速度"
          >
          </div>
        </div>

        <div class="setting-row">
          <div class="setting-copy">
            <span class="setting-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="23 4 23 10 17 10"></polyline><path
                  d="M20.49 15A9 9 0 1 1 18 5.34"></path></svg
              >
            </span>
            <div>
              <div class="set-label">朗读次数</div>
              <div class="set-info">点击单词后连续朗读的遍数</div>
            </div>
          </div>
          <div
            class="set-options"
            id="repeat-options"
            role="group"
            aria-label="朗读次数"
          >
          </div>
        </div>
      </div>
    </section>

    <section
      class="settings-card settings-storage"
      aria-labelledby="storage-settings-title"
    >
      <header class="settings-card-head">
        <div
          class="settings-card-icon settings-card-icon-warm"
          aria-hidden="true"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 12a9 9 0 0 1-9 9"></path><path d="M3 12a9 9 0 0 1 9-9"
            ></path><path d="M12 3v4"></path><path d="M12 17v4"></path><path
              d="M3 12h4"></path><path d="M17 12h4"></path></svg
          >
        </div>
        <div class="settings-card-title">
          <h2 id="storage-settings-title">数据管理</h2>
          <p>管理保存在这台设备上的查询数据</p>
        </div>
      </header>
      <div class="storage-action">
        <div>
          <strong>查询缓存</strong>
          <p>包括自动音标、在线释义和中文翻译</p>
        </div>
        <button
          class="set-btn cache-clear-btn"
          id="clear-cache-btn"
          type="button">清除缓存</button
        >
      </div>
    </section>

    <section
      class="settings-card settings-info"
      aria-labelledby="settings-info-title"
    >
      <header class="settings-card-head">
        <div
          class="settings-card-icon settings-card-icon-green"
          aria-hidden="true"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="9"></circle><path d="M12 11v5"
            ></path><path d="M12 8h.01"></path></svg
          >
        </div>
        <div class="settings-card-title">
          <h2 id="settings-info-title">帮助与说明</h2>
          <p>查看使用指南、数据来源与隐私说明</p>
        </div>
      </header>
      <nav class="settings-info-links" aria-label="帮助与说明">
        <a href="/about/">
          <span class="settings-link-icon" aria-hidden="true">L</span>
          <span><strong>关于词典</strong><small>About</small></span>
          <span class="settings-link-arrow" aria-hidden="true">›</span>
        </a>
        <a href="/guide/">
          <span class="settings-link-icon" aria-hidden="true">?</span>
          <span><strong>使用指南</strong><small>Guide</small></span>
          <span class="settings-link-arrow" aria-hidden="true">›</span>
        </a>
        <a href="/sources/">
          <span class="settings-link-icon" aria-hidden="true">⌁</span>
          <span><strong>数据来源</strong><small>Sources</small></span>
          <span class="settings-link-arrow" aria-hidden="true">›</span>
        </a>
        <a href="/privacy/">
          <span class="settings-link-icon" aria-hidden="true">✓</span>
          <span><strong>隐私与数据</strong><small>Privacy</small></span>
          <span class="settings-link-arrow" aria-hidden="true">›</span>
        </a>
      </nav>
    </section>

    <footer class="settings-card about">
      <div class="about-main">
        <div class="about-mascot">
          <img
            src="assets/lucia.png"
            width="768"
            height="768"
            loading="lazy"
            alt=""
          />
        </div>
        <div class="about-copy">
          <div class="about-name">Lucia's Dictionary</div>
          <div class="about-tag">陪 Lucia 一起学好小学英语</div>
          <div class="about-ver">v{version} · 2026</div>
        </div>
      </div>

      <div class="about-stats">
        <div class="about-stat">
          <div class="v" id="dict-count">0</div>
          <div class="l">词典收录</div>
        </div>
        <div class="about-stat">
          <div class="v" id="about-wb-count">0</div>
          <div class="l">生词本收藏</div>
        </div>
      </div>

      <div class="about-foot">
        <p>
          © 2026 <strong>Lucia &amp; Rayna</strong> · Powered by <strong
            >HIEI</strong
          >
        </p>
        <p style="margin-top:4px">
          <a href="mailto:hello@luciaandrayna.com">hello@luciaandrayna.com</a>
        </p>
      </div>
    </footer>
  </div>
</AppPanel>
