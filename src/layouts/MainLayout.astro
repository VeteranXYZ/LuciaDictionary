---
import packageJson from "../../package.json";
import {
  buildOrganizationStructuredData,
  siteLogo,
  siteName,
  siteOrigin,
} from "../lib/seo.js";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogTitle?: string;
  noindex?: boolean;
  appScript?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Lucia's Dictionary｜课堂英语句子学习词典",
  description = "输入、粘贴或拍下课堂英语句子，查看中文释义、音标和发音，并把生词保存在本地随时复习。",
  canonicalPath = "/",
  ogTitle = "Lucia's Dictionary",
  noindex = false,
  appScript = true,
  structuredData = [],
} = Astro.props;
const appVersion = packageJson.version;
const googleAnalyticsId = "G-1N76G8G0S5";
const canonicalUrl = new URL(canonicalPath, siteOrigin).toString();
const ogImage = siteLogo;
const jsonLd = [
  buildOrganizationStructuredData(),
  ...(Array.isArray(structuredData) ? structuredData : [structuredData]),
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="msvalidate.01" content="F0033F6901282859D6F7A01930532E70" />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#6B8E5A" />
    <link rel="icon" type="image/png" href={`/favicon.png?v=${appVersion}`} />
    <link
      rel="shortcut icon"
      href={`/favicon.ico?v=${appVersion}`}
      sizes="any"
    />
    <link rel="apple-touch-icon" href={`/assets/logo.png?v=${appVersion}`} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
    ></script>
    <script
      is:inline
      set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){window.dataLayer.push(arguments);}
        gtag("js", new Date());
        gtag("config", "${googleAnalyticsId}", {
          send_page_view: true,
          allow_google_signals: false,
          allow_ad_personalization_signals: false
        });
      `}
    />
    {
      jsonLd.map((item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ))
    }
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <slot />
    {appScript && <script>import "../scripts/app.js";</script>}
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
