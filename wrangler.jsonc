{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "luciadictionary",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "upload_source_maps": true,
  "send_metrics": false,
  "placement": {
    "mode": "off",
  },
  "env": {
    "production": {
      "placement": {
        "mode": "smart",
      },
    },
  },
}
